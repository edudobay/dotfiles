#!/bin/zsh

PROG_NAME=$(basename $0)

zparseopts -D -E \
    h=help -help=help \
    m=move -move=move \
    v=verbose n=dry_run

die() {
    print $@ 1>&2
    exit 1
}

usage() {
    cat <<EOF
Usage: $PROG_NAME [-m] [-v] [-n] LINK...

Replace each symbolic LINK with the file or directory it points to,
effectively "materializing" the link into a real copy in the same directory.

Options:
  -m, --move  Move (rename) the target instead of copying it. Useful when the
              target is on the same filesystem and you want to avoid duplicating
              data. The original target location will no longer exist.
  -v          Verbose — print each operation (COPY/MOVE/REMOVE) as it runs.
  -n          Dry run — print what would be done without making any changes.
              Implies -v output.
  -h, --help  Show this help message and exit.

Examples:
  $PROG_NAME ~/.vimrc            # replace symlink with a copy of the target
  $PROG_NAME -m ~/.vimrc         # replace symlink by moving the target
  $PROG_NAME -n ~/.vimrc         # preview without doing anything
  $PROG_NAME -v ~/.vimrc ~/bin   # reify multiple links, showing progress
EOF
}

if [[ -n $help ]]; then
    usage
    exit 0
fi

_do_move() {
    [[ $# -eq 2 ]] || die "internal inconsistency: _do_move:argc = $#"
    if [[ $verbose -ge 1 || -n $dry_run ]]; then
        echo 'MOVE:' $1 '=>' $2
    fi
    if [[ -z $dry_run ]]; then
        mv $1 $2
    fi
}

_do_copy() {
    [[ $# -eq 2 ]] || die "internal inconsistency: _do_copy:argc = $#"
    if [[ $verbose -ge 1 || -n $dry_run ]]; then
        echo 'COPY:' $1 '=>' $2
    fi
    if [[ -z $dry_run ]]; then
        cp -a $1 $2
    fi
}

_do_remove() {
    [[ $# -eq 1 ]] || die "internal inconsistency: _do_remove:argc = $#"
    if [[ $verbose -ge 1 || -n $dry_run ]]; then
        echo 'REMOVE:' $1
    fi
    if [[ -z $dry_run ]]; then
        rm $1
    fi
}

_reify_link() {
    [[ -h $link ]] || die "$link: not a symbolic link"

    local link_dir target
    link_dir=$(dirname $link)
    target=$(readlink -e $link)

    _do_remove $link
    if [[ -n $move ]]; then
        _do_move $target $link_dir
    else
        _do_copy $target $link_dir
    fi
}

[[ $# -gt 0 ]] || die "$PROG_NAME: no input files"
for link in $argv; do
    _reify_link $link
done

