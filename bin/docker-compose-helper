#!/usr/bin/env zsh

set -o nounset -o errexit -o pipefail

RCFILE=.dockercomposerc

args=($@)
custom_args=()

if [[ -f "$RCFILE" && ${DC_NORC-} != 1 ]]; then
    custom_args+=($(cat "$RCFILE"))
fi

if [[ ${#args[@]} -ge 1 && ${args[1]} = "ps" ]]; then
    shift 1 args
    exec docker-ps --compose "${custom_args[@]}" "${args[@]}"
fi

PS4='+ '  # be minimalist (zsh default gives filename/line for -x)
set -x

exec docker compose "${custom_args[@]}" "${args[@]}"
