# Show options and default values: `ghostty +show-config --default --docs`
# Full docs: https://ghostty.org/docs/config
# Default shortcut to reload config: Control + Shift + comma

# Font
font-size = 14
adjust-cell-height = 4

# Behavior
confirm-close-surface = true

# Scrollback limit (in BYTES)
scrollback-limit = 5000000

# Keybindings — new tab/window (cwd inherited automatically)
keybind = ctrl+shift+t=new_tab
keybind = ctrl+shift+enter=new_window

# Clear scrollback
keybind = ctrl+shift+k=reset

# Copy/paste
keybind = ctrl+shift+s=paste_from_selection

# Font size
keybind = ctrl+shift+equal=increase_font_size:1
keybind = ctrl+shift+plus=increase_font_size:1
keybind = ctrl+shift+kp_add=increase_font_size:1
keybind = ctrl+shift+minus=decrease_font_size:1
keybind = ctrl+shift+kp_subtract=decrease_font_size:1

# Tabs
keybind = ctrl+shift+left=previous_tab
keybind = ctrl+shift+right=next_tab

# Splits — create
keybind = ctrl+shift+alt+l=new_split:right
keybind = ctrl+shift+alt+j=new_split:down

# Splits — focus
keybind = ctrl+shift+[=goto_split:left
keybind = ctrl+shift+]=goto_split:right
keybind = ctrl+shift+h=goto_split:left
keybind = ctrl+shift+l=goto_split:right
keybind = ctrl+shift+k=goto_split:up
keybind = ctrl+shift+j=goto_split:down

# Splits — resize
keybind = ctrl+shift+alt+left=resize_split:left,10
keybind = ctrl+shift+alt+right=resize_split:right,10
keybind = ctrl+shift+alt+up=resize_split:up,10
keybind = ctrl+shift+alt+down=resize_split:down,10

# Splits — manage
keybind = ctrl+shift+z=toggle_split_zoom
keybind = ctrl+shift+space=equalize_splits

config-file = "theme-Japanesque.conf"
config-file = "?/home/eduardo/.config/ghostty-local.conf"
